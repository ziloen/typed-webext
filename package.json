{
  "name": "typed-webext",
  "version": "0.7.18",
  "description": "Type safe web extension api (partial)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "homepage": "https://github.com/ziloen/typed-webext",
  "scripts": {
    "build": "tsdown",
    "prepack": "npm run build",
    "release": "bumpp --commit --no-push && npm publish",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "fmt": "oxfmt"
  },
  "keywords": [
    "browser",
    "extension",
    "typescript"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "types": "./dist/react.d.ts"
    }
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/webextension-polyfill": "^0.12.5",
    "rxjs": "^7.8.2",
    "serialize-error": "<=13",
    "type-fest": "^5.6.0",
    "webextension-polyfill": ">=0.12.0 <=1.0.0"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@ziloen/eslint-config": "^0.1.82",
    "bumpp": "^11.1.0",
    "eslint": "^10.3.0",
    "oxfmt": "^0.49.0",
    "ts-lib-enhance": "^1.0.22",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "serialize-error": "<=13",
    "webextension-polyfill": ">=0.12.0 <=1.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "overrides": {
    "eslint": "$eslint"
  }
}
